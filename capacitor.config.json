{
  "appId": "com.hyperplus.app",
  "appName": "HYPER+",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0b0e14"
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0b0e14",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
